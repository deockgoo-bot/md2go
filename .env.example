# ============================================================
# HWP Converter AI Platform — Environment Variables Template
# ============================================================
# 이 파일을 복사하여 .env를 만드세요: cp .env.example .env

# App
APP_ENV=development
APP_SECRET_KEY=your-64-char-secret-key-here
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hwpbridge
POSTGRES_USER=hwpbridge
POSTGRES_PASSWORD=your-db-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_URL=redis://localhost:6379/0

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192

# Ollama (오프라인 fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
USE_OLLAMA=false

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-your-openai-key-here
EMBEDDING_DIMENSION=1536

# File Storage
UPLOAD_DIR=/tmp/hwpconverter/uploads
MAX_FILE_SIZE_MB=50

# Security
API_KEY_LENGTH=64
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000"]

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# GitHub
GITHUB_TOKEN=ghp_your-token-here
GITHUB_REPO=org/hwpx-engine

# Webhook
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT_SECONDS=30
